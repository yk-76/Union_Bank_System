      <AuxValues>
        <AuxValue name="JavaCodeGenerator_allCodePost" type="java.lang.String" value="V v = new V();&#xa;        String logAcc = v.getName(); &#xa;        System.out.println(logAcc);&#xa;        String databaseURL = &quot;jdbc:ucanaccess://C:\\Users\\User\\Documents\\NetBeansProjects\\UNION BANK SYSTEM\\src\\database\\Userdb.accdb&quot;;&#xa;        try (Connection connection = DriverManager.getConnection(databaseURL)) {&#xa;                String sqlUser = &quot;select * from User where UserName = ? &quot;;&#xa;                PreparedStatement us = connection.prepareStatement(sqlUser);                &#xa;                 us.setString(1,logAcc);&#xa;                ResultSet resultUser = us.executeQuery();&#xa;                    if(resultUser.next()){&#xa;                         String acc=resultUser.getString(&quot;accountNumber&quot;);&#xa;                         String Name=resultUser.getString(&quot;Name&quot;);&#xa;                         System.out.println(acc);&#xa;                            displayUserID1.setText(logAcc);&#xa;                            displayAccNum.setText(acc);&#xa;                            displayName.setText(Name);&#xa;                            displayCurrentBalance.setText(&quot;RM****.**&quot;);&#xa;                      }&#xa;                 connection.close();  &#xa;                }catch (Exception e){&#xa;                System.err.println(&quot;Got an exception!&quot;);&#xa;              &#xa;                e.printStackTrace();&#xa;                &#xa;                System.out.println(e); &#xa;                }"/>
      </AuxValues>

