      <AuxValues>
        <AuxValue name="JavaCodeGenerator_allCodePost" type="java.lang.String" value="V v=new V();&#xd;&#xa;String role = v.getRole();&#xd;&#xa;System.out.println(role);&#xd;&#xa;if(role.equals(&quot;Admin&quot;) ){&#xd;&#xa;transferUserBTN.setVisible(false);&#xd;&#xa;historyBTN.setVisible(false);&#xd;&#xa;closeUserBTN.setVisible(false);&#xd;&#xa;}else if ( role.equals(&quot;User&quot;)){&#xd;&#xa;registerBTN.setVisible(false);&#xd;&#xa;depositBTN.setVisible(false);&#xd;&#xa;withdrawalBTN.setVisible(false);&#xd;&#xa;historyDetailBTN.setVisible(false);&#xd;&#xa;transferAdminBTN.setVisible(false);&#xd;&#xa;closeAdminBTN.setVisible(false);&#xd;&#xa;}else{&#xd;&#xa;JOptionPane.showMessageDialog(this, &quot;Please contact to the authority as soon as possible!&quot;);&#xd;&#xa;}"/>
      </AuxValues>

