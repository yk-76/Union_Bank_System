              <AuxValues>
                <AuxValue name="JavaCodeGenerator_allCodePost" type="java.lang.String" value=" V v = new V();&#xa;        String inacc=v.getName();&#xa;        String databaseURL = &quot;jdbc:ucanaccess://C:\\Users\\User\\Documents\\NetBeansProjects\\UNION BANK SYSTEM\\src\\database\\Userdb.accdb&quot;;&#xa;        try (Connection connection = DriverManager.getConnection(databaseURL)) {&#xa;            &#xa;                String sql = &quot;select * from Account WHERE accountNumber = ? &quot;;&#xa;                PreparedStatement us = connection.prepareStatement(sql);                &#xa;                us.setString(1,inacc); &#xa;                ResultSet result = us.executeQuery();&#xa;                    while(result.next()){&#xa;                        int bal=result.getInt(&quot;balance&quot;);&#xa;                        String acc=result.getString(&quot;accountNumber&quot;);&#xa;                        &#xa;                    displayAmount.setText(&quot;RM&quot;+Double.toString(bal));&#xa;                    System.out.println(&quot;The amount for &quot;+acc+&quot; is: RM&quot;+bal);                          &#xa;                }&#xa;                 connection.close();  &#xa;                }catch (Exception e){&#xa;                System.err.println(&quot;Got an exception!&quot;);&#xa;              &#xa;                e.printStackTrace();&#xa;                &#xa;                System.out.println(e); &#xa;                }&#xa;       &#xa;        String loginAcc = v.getName();&#xa;        &#xa;        BankFunction BF = new BankFunction();&#xa;&#xa;        DefaultTableModel tableHistory = (DefaultTableModel)historyTable1.getModel();&#xa;        try (Connection connection = DriverManager.getConnection(databaseURL)) {&#xa;            BF.tableAcc_in(connection,loginAcc,tableHistory);&#xa;&#xa;            BF.tableAcc_out(connection,loginAcc,tableHistory);&#xa;&#xa;        }catch (Exception e){&#xa;            System.err.println(&quot;Got an exception!&quot;);&#xa;&#xa;            e.printStackTrace();&#xa;&#xa;            System.out.println(e);&#xa;        }&#xa;&#xa;        // Sort the table based on transactionID column&#xa;        TableRowSorter&lt;DefaultTableModel&gt; sorter = new TableRowSorter&lt;&gt;(tableHistory);&#xa;        historyTable1.setRowSorter(sorter);&#xa;        sorter.setSortKeys(java.util.Collections.singletonList(new javax.swing.RowSorter.SortKey(0, javax.swing.SortOrder.ASCENDING)));&#xa;    "/>
              </AuxValues>
            </Component>
